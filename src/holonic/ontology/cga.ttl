@prefix cga:     <urn:holonic:ontology:> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix schema:  <https://schema.org/> .

# ══════════════════════════════════════════════════════════════
# Context-Graph Architecture (CGA) Ontology  v0.3.0
#
# Six concerns:
#   1. Structure    — holons, layers, portals, holarchies
#   2. Typing       — functional and lifecycle classification
#   3. Governance   — authority, stewardship, classification
#   4. Process      — binding holons to business processes
#   5. Operations   — freshness, sizing, materialization
#   6. Lifecycle    — split, merge, archive, supersession
# ══════════════════════════════════════════════════════════════

cga: a owl:Ontology ;
    rdfs:label "Context-Graph Architecture Ontology" ;
    dcterms:description """Defines the structural vocabulary for holonic RDF
        systems: holons (entities with four-layer named-graph structure),
        portals (governed traversal mechanisms between holons), and
        holarchies (nested holon systems).  Extended with governance,
        process binding, lifecycle management, and operational metadata
        for enterprise deployment.""" ;
    owl:versionInfo "0.3.0" ;
    dcterms:created "2026-04-03"^^xsd:date .


# ══════════════════════════════════════════════════════════════
# 1. STRUCTURAL CLASSES
# ══════════════════════════════════════════════════════════════

cga:Holon a owl:Class ;
    rdfs:label "Holon" ;
    skos:definition """A knowledge-graph entity with genuine inside/outside
        distinction, comprising one or more named graphs per layer
        (interior, boundary, projection, context) and an IRI that
        anchors all layers as a coherent identity.""" .

cga:Portal a owl:Class ;
    rdfs:label "Portal" ;
    skos:definition """A boundary-membrane object that governs traversal
        between holons.  First-class RDF entity with its own IRI.""" .

cga:TransformPortal a owl:Class ;
    rdfs:subClassOf cga:Portal ;
    rdfs:label "Transform Portal" ;
    skos:definition """A portal carrying a SPARQL CONSTRUCT query to
        reshape data during traversal.""" .

cga:SealedPortal a owl:Class ;
    rdfs:subClassOf cga:Portal ;
    rdfs:label "Sealed Portal" ;
    skos:definition """A portal whose target exists but traversal is
        currently blocked.  IRI persists.""" .

cga:LayerGraph a owl:Class ;
    rdfs:label "Layer Graph" ;
    skos:definition """A named graph serving as one layer of a holon.
        A holon may have multiple LayerGraphs per role.""" .

# ── Layer roles ──

cga:LayerRole a owl:Class ;
    rdfs:label "Layer Role" .

cga:InteriorRole a cga:LayerRole ;
    rdfs:label "Interior" ;
    skos:definition "Epistemically grounded assertions and domain data." .

cga:BoundaryRole a cga:LayerRole ;
    rdfs:label "Boundary" ;
    skos:definition "SHACL shapes and portal definitions — the membrane." .

cga:ProjectionRole a cga:LayerRole ;
    rdfs:label "Projection" ;
    skos:definition "External bindings, vocabulary alignments, realization declarations." .

cga:ContextRole a cga:LayerRole ;
    rdfs:label "Context" ;
    skos:definition "Provenance, temporal annotations, operational history." .

# ── Portal directionality ──

cga:PortalType a owl:Class .
cga:UnidirectionalPortal a cga:PortalType ; rdfs:label "Unidirectional" .
cga:BidirectionalPortal  a cga:PortalType ; rdfs:label "Bidirectional" .

# ── Membrane health ──

cga:MembraneHealth a owl:Class .
cga:Intact      a cga:MembraneHealth ; rdfs:label "Intact" ;
    skos:definition "No violations or warnings." .
cga:Weakened    a cga:MembraneHealth ; rdfs:label "Weakened" ;
    skos:definition "Warnings present, no violations." .
cga:Compromised a cga:MembraneHealth ; rdfs:label "Compromised" ;
    skos:definition "Violations present — membrane breached." .


# ══════════════════════════════════════════════════════════════
# 2. HOLON TYPE TAXONOMY
# ══════════════════════════════════════════════════════════════

# ── Functional types ──

cga:DataHolon a owl:Class ;
    rdfs:subClassOf cga:Holon ;
    rdfs:label "Data Holon" ;
    skos:definition "Contains domain data.  Boundaries validate quality." .

cga:AlignmentHolon a owl:Class ;
    rdfs:subClassOf cga:Holon ;
    rdfs:label "Alignment Holon" ;
    skos:definition """Contains vocabulary mappings (rdfs:subPropertyOf,
        rdfs:subClassOf axioms).  Portals reference this holon via
        cga:usesAlignment for semantic justification.""" .

cga:AgentHolon a owl:Class ;
    rdfs:subClassOf cga:Holon ;
    rdfs:label "Agent Holon" ;
    skos:definition """Represents an active computational agent.  Interior =
        agent memory.  Boundary = output constraints.  Context =
        execution history.  Projection = capability interface.""" .

cga:GovernanceHolon a owl:Class ;
    rdfs:subClassOf cga:Holon ;
    rdfs:label "Governance Holon" ;
    skos:definition """Contains policies, access controls, governance rules.
        A policy container, not a data container.""" .

cga:AggregateHolon a owl:Class ;
    rdfs:subClassOf cga:Holon ;
    rdfs:label "Aggregate Holon" ;
    skos:definition """No original data — interiors populated entirely by
        portal traversals.  A materialized view.""" .

cga:IndexHolon a owl:Class ;
    rdfs:subClassOf cga:Holon ;
    rdfs:label "Index Holon" ;
    skos:definition """Discovery metadata: type indexes, search indexes,
        embedding vectors.  Enables type-directed holon discovery.""" .

# ── Lifecycle types ──

cga:EphemeralHolon a owl:Class ;
    rdfs:subClassOf cga:Holon ;
    rdfs:label "Ephemeral Holon" ;
    skos:definition "Short-lived: task-scoped, archived on completion." .

cga:PersistentHolon a owl:Class ;
    rdfs:subClassOf cga:Holon ;
    rdfs:label "Persistent Holon" ;
    skos:definition "Long-lived: enduring organizational entity or domain." .


# ══════════════════════════════════════════════════════════════
# 3. GOVERNANCE CLASSES
# ══════════════════════════════════════════════════════════════

cga:DataDomain a owl:Class ;
    rdfs:label "Data Domain" ;
    skos:definition """Named area of data governance.  Holons declare
        source-of-truth or repository-of-truth for specific domains.""" .

cga:BusinessProcess a owl:Class ;
    rdfs:label "Business Process" ;
    skos:definition """Organizational process that produces, consumes,
        or governs holon data.""" .

cga:ExternalSystem a owl:Class ;
    rdfs:label "External System" ;
    skos:definition """System outside the holarchy providing/receiving data.
        SharePoint, Workday, DOORS, REST API, etc.""" .

cga:Capability a owl:Class ;
    rdfs:label "Capability" ;
    skos:definition """Service a holon offers, declared with input/output
        SHACL shapes for structural compatibility checking.""" .


# ══════════════════════════════════════════════════════════════
# 4. LIFECYCLE CLASSES
# ══════════════════════════════════════════════════════════════

cga:HolonStatus a owl:Class ;
    rdfs:label "Holon Status" .

cga:Active a cga:HolonStatus ;
    rdfs:label "Active" ;
    skos:definition "Live.  Receives data, portals route to it." .

cga:Archived a cga:HolonStatus ;
    rdfs:label "Archived" ;
    skos:definition "Retired.  Frozen interiors. Still queryable. Never deleted." .

cga:Proposed a cga:HolonStatus ;
    rdfs:label "Proposed" ;
    skos:definition "Awaiting governance approval." .

cga:HolonSplit a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Holon Split" ;
    skos:definition "Activity dividing one holon into successors." .

cga:HolonMerge a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Holon Merge" ;
    skos:definition "Activity combining holons into one successor." .


# ══════════════════════════════════════════════════════════════
# 5. OBJECT PROPERTIES
# ══════════════════════════════════════════════════════════════

# ── Layer bindings ──
cga:hasLayer      a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range cga:LayerGraph .
cga:hasInterior   a owl:ObjectProperty ; rdfs:subPropertyOf cga:hasLayer ; rdfs:domain cga:Holon .
cga:hasBoundary   a owl:ObjectProperty ; rdfs:subPropertyOf cga:hasLayer ; rdfs:domain cga:Holon .
cga:hasProjection a owl:ObjectProperty ; rdfs:subPropertyOf cga:hasLayer ; rdfs:domain cga:Holon .
cga:hasContext    a owl:ObjectProperty ; rdfs:subPropertyOf cga:hasLayer ; rdfs:domain cga:Holon .
cga:layerRole     a owl:ObjectProperty ; rdfs:domain cga:LayerGraph ; rdfs:range cga:LayerRole .

# ── Portal ──
cga:sourceHolon    a owl:ObjectProperty ; rdfs:domain cga:Portal ; rdfs:range cga:Holon .
cga:targetHolon    a owl:ObjectProperty ; rdfs:domain cga:Portal ; rdfs:range cga:Holon .
cga:portalType     a owl:ObjectProperty ; rdfs:domain cga:Portal ; rdfs:range cga:PortalType .
cga:usesAlignment  a owl:ObjectProperty ; rdfs:domain cga:Portal ; rdfs:range cga:AlignmentHolon ;
    skos:definition "Alignment holon justifying this portal's transformation." .
cga:sourceRealizes a owl:ObjectProperty ; rdfs:domain cga:Portal ;
    skos:definition "Logical entity the source platform type realizes." .
cga:targetRealizes a owl:ObjectProperty ; rdfs:domain cga:Portal ;
    skos:definition "Logical entity the target platform type realizes." .

# ── Holarchy structure ──
cga:memberOf     a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range cga:Holon .
cga:adjacentTo   a owl:ObjectProperty, owl:SymmetricProperty ; rdfs:domain cga:Holon ; rdfs:range cga:Holon .
cga:bindsTo      a owl:ObjectProperty ; rdfs:domain cga:Holon .
cga:exposesPortal a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range cga:Portal .

# ── Authority ──
cga:sourceOfTruthFor     a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range cga:DataDomain ;
    skos:definition "This holon is the authoritative originator for this data domain." .
cga:repositoryOfTruthFor a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range cga:DataDomain ;
    skos:definition "This holon is the authoritative serving point for this data domain." .
cga:derivedFrom          a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range cga:Holon ;
    skos:definition """Persistent structural dependency between two holons: the
        subject holon's identity or purpose continues to depend on the object
        holon. Captured at the holon level, not the named-graph level, and
        independent of any particular activity or event.

        Distinct from prov:wasDerivedFrom. prov:wasDerivedFrom is PROV-O's
        event-level derivation between entities generated by a specific
        activity (e.g. one interior graph being produced by a portal
        traversal from another interior graph). cga:derivedFrom is a
        stable declaration of ongoing dependency with no activity
        requirement. Both may coexist: a portal traversal records
        prov:wasDerivedFrom between the specific graphs it wrote; the
        enduring holon-to-holon dependency is declared separately with
        cga:derivedFrom.""" ;
    rdfs:seeAlso prov:wasDerivedFrom .

# ── Stewardship ──
cga:dataSteward a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range schema:Person .
cga:dataOwner   a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range schema:Person .

# ── Process ──
cga:producedByProcess a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range cga:BusinessProcess .
cga:consumedByProcess a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range cga:BusinessProcess .
cga:governedByProcess a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range cga:BusinessProcess .
cga:processStage      a owl:ObjectProperty ; rdfs:domain cga:BusinessProcess .

# ── External system ──
cga:backedBySystem a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range cga:ExternalSystem .

# ── Capability ──
cga:providesCapability a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range cga:Capability .
cga:requiresInput      a owl:ObjectProperty ; rdfs:domain cga:Capability .
cga:producesOutput     a owl:ObjectProperty ; rdfs:domain cga:Capability .

# ── Lifecycle ──
cga:holonStatus  a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range cga:HolonStatus .
cga:supersededBy a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range cga:Holon .
cga:splitTarget  a owl:ObjectProperty ; rdfs:domain cga:HolonSplit ; rdfs:range cga:Holon .

# ── Discovery index ──
cga:containsType a owl:ObjectProperty ; rdfs:domain cga:Holon ; rdfs:range rdfs:Class ;
    skos:definition "This holon's interiors contain instances of this rdf:type." .

# ── Data domain governance ──
cga:domainSteward a owl:ObjectProperty ; rdfs:domain cga:DataDomain ; rdfs:range schema:Person .
cga:domainPolicy  a owl:ObjectProperty ; rdfs:domain cga:DataDomain .

# ── Membrane health (on provenance activities) ──
cga:membraneHealth a owl:ObjectProperty ; rdfs:domain prov:Activity ; rdfs:range cga:MembraneHealth .


# ══════════════════════════════════════════════════════════════
# 6. DATATYPE PROPERTIES
# ══════════════════════════════════════════════════════════════

# ── Structural ──
cga:holonDepth      a owl:DatatypeProperty ; rdfs:domain cga:Holon ; rdfs:range xsd:integer ;
    skos:definition "Optional. Derivable from cga:memberOf chain." .
cga:constructQuery  a owl:DatatypeProperty ; rdfs:domain cga:TransformPortal ; rdfs:range xsd:string .
cga:isTraversable   a owl:DatatypeProperty ; rdfs:domain cga:Portal ; rdfs:range xsd:boolean .
cga:activationEvent a owl:DatatypeProperty ; rdfs:domain cga:Portal ; rdfs:range xsd:string .

# ── Governance ──
cga:dataClassification a owl:DatatypeProperty ; rdfs:domain cga:Holon ; rdfs:range xsd:string ;
    skos:definition "Data sensitivity: PUBLIC, CUI, PII, SECRET, etc." .
cga:gateCondition      a owl:DatatypeProperty ; rdfs:domain cga:BusinessProcess ; rdfs:range xsd:string .

# ── Operational ──
cga:lastIngestion       a owl:DatatypeProperty ; rdfs:domain cga:Holon ; rdfs:range xsd:dateTime .
cga:refreshFrequency    a owl:DatatypeProperty ; rdfs:domain cga:Holon ; rdfs:range xsd:duration ;
    skos:definition "Expected refresh interval. P0D=manual, PT1H=hourly, P1D=daily." .
cga:interiorTripleCount a owl:DatatypeProperty ; rdfs:domain cga:Holon ; rdfs:range xsd:integer .
cga:materializationMode a owl:DatatypeProperty ; rdfs:domain cga:Holon ; rdfs:range xsd:string ;
    skos:definition "materialized | virtualized | cached | hybrid" .

# ── Lifecycle ──
cga:splitRationale a owl:DatatypeProperty ; rdfs:domain cga:HolonSplit ; rdfs:range xsd:string .
cga:mergeRationale a owl:DatatypeProperty ; rdfs:domain cga:HolonMerge ; rdfs:range xsd:string .
cga:splitCriteria  a owl:DatatypeProperty ; rdfs:domain cga:HolonSplit ; rdfs:range xsd:string ;
    skos:definition "SPARQL CONSTRUCT determining which triples went to which successor." .

# ── External system ──
cga:systemType     a owl:DatatypeProperty ; rdfs:domain cga:ExternalSystem ; rdfs:range xsd:string .
cga:systemEndpoint a owl:DatatypeProperty ; rdfs:domain cga:ExternalSystem ; rdfs:range xsd:anyURI .


# ══════════════════════════════════════════════════════════════
# 7. GRAPH-LEVEL METADATA  (added in 0.3.3)
#
# Per-graph operational metadata lives in the registry graph
# (urn:holarchy:registry by default, configurable via
# HolonicDataset(registry_graph_iri=...)). Subjects are LayerGraph
# IRIs; objects are counts, timestamps, or ClassInstanceCount
# records.
#
# See docs/DECISIONS.md § D-0.3.3-3 for the rationale on reified
# inventory records vs direct predicates.
# ══════════════════════════════════════════════════════════════

cga:ClassInstanceCount a owl:Class ;
    rdfs:label "Class Instance Count" ;
    skos:definition """Reified record of how many instances of a given
        rdf:type exist in a specific LayerGraph. Subjects are IRIs of
        the form <graph-iri>/inventory/<slug> so records are
        addressable and idempotent to refresh.""" .

# Per-graph properties (subjects are LayerGraph IRIs)
cga:tripleCount    a owl:DatatypeProperty ; rdfs:domain cga:LayerGraph ; rdfs:range xsd:integer ;
    skos:definition "Number of triples in this named graph at lastModified time." .
cga:lastModified   a owl:DatatypeProperty ; rdfs:domain cga:LayerGraph ; rdfs:range xsd:dateTime ;
    skos:definition "Timestamp of the most recent library-mediated write to this graph, UTC microsecond precision." .
cga:refreshedAt    a owl:DatatypeProperty ; rdfs:range xsd:dateTime ;
    skos:definition "Timestamp of the last metadata refresh. Applies to LayerGraph and ClassInstanceCount." .

# ClassInstanceCount properties
cga:inGraph        a owl:ObjectProperty ; rdfs:domain cga:ClassInstanceCount ; rdfs:range cga:LayerGraph ;
    skos:definition "The graph this inventory record covers." .
cga:class          a owl:ObjectProperty ; rdfs:domain cga:ClassInstanceCount ; rdfs:range rdfs:Class ;
    skos:definition "The rdf:type being counted." .
cga:count          a owl:DatatypeProperty ; rdfs:domain cga:ClassInstanceCount ; rdfs:range xsd:integer ;
    skos:definition "Number of instances of cga:class in cga:inGraph." .

# Per-holon rollup (subject is the Holon IRI)
cga:holonLastModified a owl:DatatypeProperty ; rdfs:domain cga:Holon ; rdfs:range xsd:dateTime ;
    skos:definition "Max of lastModified across this holon's layer graphs." .


# ══════════════════════════════════════════════════════════════
# 8. GRAPH TYPE VOCABULARY  (added in 0.3.4)
#
# Named graphs playing a holonic role (interior, boundary,
# projection, context, registry) are typed explicitly in the
# registry graph. The typing uses one umbrella class
# (cga:HolonicGraph) and a role property (cga:graphRole) ranged
# over LayerRole individuals.
#
# This is a flat + role pattern, not a subclass hierarchy. Rationale
# in docs/DECISIONS.md § D-0.3.4-1. A graph can carry multiple
# cga:graphRole values, which the subclass pattern would forbid.
#
# Note: cga:HolonicGraph is distinct from cga:LayerGraph.
#   cga:LayerGraph refers to the structural concept of "a named
#   graph playing a layer role for some holon".
#   cga:HolonicGraph is the RDF type placed on actual graph IRIs
#   in the registry, for discoverability by type-based queries.
#   Every registered layer graph in practice carries both labels
#   via rdfs:subClassOf (below).
# ══════════════════════════════════════════════════════════════

cga:HolonicGraph a owl:Class ;
    rdfs:label "Holonic Graph" ;
    skos:definition """An RDF named graph playing a categorized role
        in a holarchy (interior, boundary, projection, context, or
        registry). Typing is materialized in the registry graph so
        that type-based discovery works via standard SPARQL without
        entailment reasoning.""" .

# Every LayerGraph is also a HolonicGraph; the converse is not true
# (the registry graph is a HolonicGraph but not a LayerGraph).
cga:LayerGraph rdfs:subClassOf cga:HolonicGraph .

cga:graphRole a owl:ObjectProperty ;
    rdfs:domain cga:HolonicGraph ;
    rdfs:range cga:LayerRole ;
    skos:definition """The role this graph plays in its containing
        holon (or in the holarchy, for the registry graph). A graph
        may carry multiple graphRole values; callers should treat
        the set as a union of capabilities.""" .

cga:RegistryRole a cga:LayerRole ;
    rdfs:label "Registry" ;
    skos:definition """The cross-cutting catalog graph for the
        holarchy. Contains holon declarations, portal declarations,
        graph-typing triples, and graph-level operational metadata.
        Not a layer of any particular holon.""" .

# ══════════════════════════════════════════════════════════════
# 9. PROJECTION PIPELINE VOCABULARY  (added in 0.3.5)
#
# Projection pipelines are RDF-modeled specs stored in the registry.
# A ProjectionPipelineSpec carries an rdf:List of
# ProjectionPipelineStep resources. Holons attach to pipelines via
# cga:hasPipeline. Running a pipeline produces a prov:Activity in
# the holon's context graph with links to the pipeline, output
# graph, transforms used (name + version), and host metadata.
#
# Rationale: docs/DECISIONS.md § 0.3.5.
# ══════════════════════════════════════════════════════════════

cga:ProjectionPipelineSpec a owl:Class ;
    rdfs:label "Projection Pipeline Spec" ;
    skos:definition """A named, ordered composition of projection
        steps. Steps are referenced via cga:hasStep as an rdf:List
        to preserve order. Holons reference a pipeline via
        cga:hasPipeline.""" .

cga:ProjectionPipelineStep a owl:Class ;
    rdfs:label "Projection Pipeline Step" ;
    skos:definition """One step in a pipeline. Carries either a
        cga:transformName (a registered Python transform, looked up
        via the holonic.projections entry-point group at run time)
        or a cga:constructQuery (inline SPARQL CONSTRUCT). At least
        one must be present. When both are present, the transform
        runs first, then the CONSTRUCT is applied to its output.""" .

cga:hasPipeline a owl:ObjectProperty ;
    rdfs:domain cga:Holon ;
    rdfs:range cga:ProjectionPipelineSpec ;
    skos:definition "Declares that this holon has a named projection pipeline available." .

cga:hasStep a owl:ObjectProperty ;
    rdfs:domain cga:ProjectionPipelineSpec ;
    rdfs:range rdf:List ;
    skos:definition "Ordered list of ProjectionPipelineStep resources via rdf:first/rest." .

cga:stepName a owl:DatatypeProperty ;
    rdfs:domain cga:ProjectionPipelineStep ;
    rdfs:range xsd:string ;
    skos:definition "Human-readable label for this step; aids debugging." .

cga:transformName a owl:DatatypeProperty ;
    rdfs:domain cga:ProjectionPipelineStep ;
    rdfs:range xsd:string ;
    skos:definition "Entry-point name of a registered Python transform (holonic.projections group)." .

# Note: cga:constructQuery is reused from the portal vocabulary. Its
# domain is widened implicitly to include ProjectionPipelineStep;
# a single datatype property can apply to multiple class contexts.

# ── Provenance extensions for projection runs ──

cga:transformVersion a owl:DatatypeProperty ;
    rdfs:domain prov:Activity ;
    rdfs:range xsd:string ;
    skos:definition """Package+version identifier for one transform
        used during a projection run. Format: 'pkg-name==version'.
        Multiple values allowed, one per transform referenced by the
        pipeline.""" .

cga:runHost a owl:DatatypeProperty ;
    rdfs:domain prov:Activity ;
    rdfs:range xsd:string ;
    skos:definition "Hostname of the machine that ran this activity." .

cga:runPlatform a owl:DatatypeProperty ;
    rdfs:domain prov:Activity ;
    rdfs:range xsd:string ;
    skos:definition "OS + architecture string, e.g. 'Linux-5.15-x86_64'." .

cga:runPythonVersion a owl:DatatypeProperty ;
    rdfs:domain prov:Activity ;
    rdfs:range xsd:string ;
    skos:definition "Python interpreter version, e.g. '3.12.3'." .

cga:runHolonicVersion a owl:DatatypeProperty ;
    rdfs:domain prov:Activity ;
    rdfs:range xsd:string ;
    skos:definition "holonic library version active during the run." .
