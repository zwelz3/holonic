                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000965"/>
        <rdfs:comment xml:lang="en">Specification of the conventions for constructing and using a View

Source: ISO/IEC/IEEE 15288:2023</rdfs:comment>
        <rdfs:label>Viewpoint</rdfs:label>
        <skos:definition xml:lang="en">A set of conventions for the creation, interpretation and use of a View to frame one or more Concerns</skos:definition>
        <cco:ont00001754 xml:lang="en">derived from ISO/IEC/IEEE 24641:2023 - Systems and Software engineering — Methods and tools for model-based systems and software engineering</cco:ont00001754>
    </owl:Class>
    


