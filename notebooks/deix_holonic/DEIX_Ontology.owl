    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://semantic.incose.org/DEIX_Ontology#Acceptance_Criteria -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Acceptance_Criteria">
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000965"/>
        <rdfs:label xml:lang="en">Acceptance Criteria</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Act_of_Data_Transfer -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Data_Transfer">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000402"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Data_Transfer_Function"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001921"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000958"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001986"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000958"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000402"/>
        <rdfs:label>Act of Data Transfer</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Engineering -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Engineering">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Engineering"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000057"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Artifact"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001778"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Authoritative_Source_of_Truth"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Engineering"/>
        <rdfs:label xml:lang="en">Act of Digital Engineering</rdfs:label>
        <skos:definition xml:lang="en">An Act of Engineering that uses Digital Artifact(s) with the intent of producing Authoritative Source(s) of Truth</skos:definition>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Simulation -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Simulation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Tool_Use"/>
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Simulation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001921"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Authoritative_Source_of_Truth"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001986"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Artifact"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Simulation"/>
        <rdfs:label xml:lang="en">Act of Digital Simulation</rdfs:label>
        <skos:definition xml:lang="en">An Act of Simulation and Digital Tool Use which takes as its input an Authoritative Source of Truth to produce a Digital Artifact as its output.</skos:definition>
        <skos:editorialNote xml:lang="en">Narrows the definition of Act of Simulation to make use of ASoT and Digital Artifact</skos:editorialNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Tool_Use -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Tool_Use">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000513"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001949"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Tool"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000513"/>
        <rdfs:label xml:lang="en">Act of Digital Tool Use</rdfs:label>
        <skos:definition xml:lang="en">An Act of Artifact Employment in which some Agent uses some Digital Tool.</skos:definition>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Transformation -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Transformation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000228"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000066"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00001180"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001866"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Stakeholder"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001986"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Environment"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000228"/>
        <rdfs:comment xml:lang="en">The process of adoption and implementation of digital technology by an Organization in order to create new or modify existing Products, Services and operations by the means of translating business processes into a digital format.

Source: https://en.wikipedia.org/wiki/Digital_transformation</rdfs:comment>
        <rdfs:label xml:lang="en">Act of Digital Transformation</rdfs:label>
        <skos:definition xml:lang="en">A Planned Act of profound and radical change through Digital technologies that orients an Organization in a new direction and takes it to an entirely different level of effectiveness, which is based on analytics of Data</skos:definition>
        <skos:editorialNote xml:lang="en">TBR: Needs revision</skos:editorialNote>
        <skos:scopeNote xml:lang="en">TBR: May be more appropriate in a Digital Enterprise domain ontology</skos:scopeNote>
        <cco:ont00001753 xml:lang="en">DT</cco:ont00001753>
        <cco:ont00001754 xml:lang="en">ISO/IEC TS 30105-9:2023 - Information technology — IT Enabled Services-Business Process Outsourcing (ITES-BPO) lifecycle processes — Part 9: Guidelines on extending process capability assessment for digital transformation</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Act_of_Engineering -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Engineering">
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000228"/>
        <rdfs:label xml:lang="en">Act of Engineering</rdfs:label>
        <skos:scopeNote xml:lang="en">TBR: move concept to Engineering (?) domain ontology</skos:scopeNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Act_of_Establishing_Traceability -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Establishing_Traceability">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000366"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001778"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Traceability_Relationship"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000366"/>
        <rdfs:label xml:lang="en">Act of Establishing Traceability</rdfs:label>
        <skos:definition xml:lang="en">An Act of Information Processing that involves discerning a Traceability Relationship among two or more logical entities</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">derived from ISO/IEC/IEEE 15288:2023, 3.52</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Act_of_Governance -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Governance">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000133"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001833"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Stakeholder"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001857"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Lifecycle"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000133"/>
        <rdfs:label xml:lang="en">Act of Governance</rdfs:label>
        <skos:definition xml:lang="en">An Act of Directive Communication by a human-based System comprising directing, overseeing and accountability</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering or other domain ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">derived from ISO/IEC 38500:2024</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Act_of_Managing_Consistency -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Managing_Consistency">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000366"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001777"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Measuring_Consistency"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000366"/>
        <rdfs:label xml:lang="en">Act of Managing Consistency</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Act_of_Measuring_Consistency -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Measuring_Consistency">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000345"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001986"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Consistency_Measurement_Information_Content_Entity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000345"/>
        <rdfs:label xml:lang="en">Act of Measuring Consistency</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Act_of_Model_Curation -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Model_Curation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000908"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001778"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Asset"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001857"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Lifecycle"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000908"/>
        <rdfs:label xml:lang="en">Act of Model Curation</rdfs:label>
        <skos:definition xml:lang="en">An Act of Artifact Processing that is part of some System Lifecycle and whose intent is the curation of a Digital Asset</skos:definition>
        <skos:editorialNote xml:lang="en">NOTE: We have not detailed this process, &quot;Act of Model Curation&quot;, and it presumably involves many process parts.</skos:editorialNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Act_of_Role_Assignment -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Role_Assignment">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001032"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001778"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001833"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Authority"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001857"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Governance"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00001032"/>
        <rdfs:label xml:lang="en">Act of Role Assignment</rdfs:label>
        <skos:definition xml:lang="en">An Act of Assignment enacted by an Authority, which is a part of an Act of Governance process and whose object is a role</skos:definition>
        <skos:editorialNote xml:lang="en">Needed for Authoritative Source of Truth, because an Authority is one who assigns the Authoritative Source of Truth Role to a Digital Asset thru an Act of Role Assignment</skos:editorialNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Act_of_Simulation -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Act_of_Simulation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000513"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001921"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000958"/>
                                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001045"/>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001986"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#System_View"/>
                                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000958"/>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000513"/>
        <rdfs:comment xml:lang="en">use of a similar or equivalent System to imitate a real System, so that it behaves like or appears to be the real System

Source: ISO/IEC 30173:2023, 3.5.4</rdfs:comment>
        <rdfs:label xml:lang="en">Act of Simulation</rdfs:label>
        <skos:definition xml:lang="en">The process of using a Model that behaves or operates like a given System when provided a set of controlled inputs.</skos:definition>
        <skos:editorialNote xml:lang="en">Not necessarily Digital</skos:editorialNote>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">ISO/IEC/IEEE 24765:2010</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Activity -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Activity">
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000228"/>
        <rdfs:label xml:lang="en">Activity</rdfs:label>
        <skos:definition xml:lang="en">set of cohesive Tasks of a process</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">ISO/IEC/IEEE 15288:2023</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Approach -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Approach">
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000965"/>
        <rdfs:label xml:lang="en">Approach</rdfs:label>
        <skos:definition xml:lang="en">The prescribed method used in dealing with or accomplishing.</skos:definition>
        <skos:editorialNote xml:lang="en">Serves as the superclass of Digital Engineering Approach, used to disambiguate &quot;Digital Engineering&quot;</skos:editorialNote>
        <skos:scopeNote xml:lang="en">TBR: move concept to Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">derived from The American Heritage® Dictionary of the English Language, 5th Edition</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Asset -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Asset">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000740"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001936"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000636"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000740"/>
        <rdfs:comment xml:lang="en">entity that the owner of the Target of Evaluation presumably places value on

Source: ISO/IEC 15408-1:2022 - Information security, cybersecurity and privacy protection - Evaluation critera for IT security - Part 1: Introduction and general model</rdfs:comment>
        <rdfs:label xml:lang="en">Asset</rdfs:label>
        <skos:definition xml:lang="en">a Resource that is the object of an Act of Appraisal</skos:definition>
        <skos:editorialNote xml:lang="en">Serves as superclass of Digital Asset</skos:editorialNote>
        <skos:scopeNote xml:lang="en">Would likely be defined in an Evaluation Assurance domain ontology based on ISO/IEC 15408, or some higher-level domain ontology such as Mission Engineering</skos:scopeNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Authoritative_Knowledge -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Authoritative_Knowledge">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Knowledge"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000178"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000592"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Knowledge"/>
        <rdfs:comment xml:lang="en">CONJECTURE Ω(Α) = &lt;φ|θ|α(Α)&gt;
            - Ω : Authoritative Knowledge
            - A : &apos;as-is&apos; subject, in context of an application
            - φ : Utility of Representation (i.e., Model Elegance)
            - θ : Parameters of Curation
            - α-hat : Representation &apos;is output of&apos; Act of Model Curation
            - α-hat(A) : Representation (α-hat) in an ASoT of an &apos;as-is&apos; subject (A)

Source: Clarence &quot;Moe&quot; Moreland, (2024) &quot;ASOT Definition/Certification Process&quot;, Presentation, INCOSE Digital Engineering Information eXchange (DEIX) Ontology Working Group.</rdfs:comment>
        <rdfs:label xml:lang="en">Authoritative Knowledge</rdfs:label>
        <skos:definition xml:lang="en">Knowledge that carries a Veracity Measurement ICE</skos:definition>
        <skos:editorialNote xml:lang="en">Used in the definition of Authoritative Source of Truth</skos:editorialNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Authoritative_Source_of_Truth_Role -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Authoritative_Source_of_Truth_Role">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Source_of_Truth_Role"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Role_Assignment"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://semantic.incose.org/DEIX_Ontology#has_ASOT_Context"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Engineering"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Source_of_Truth_Role"/>
        <rdfs:label xml:lang="en">Authoritative Source of Truth Role</rdfs:label>
        <skos:altLabel xml:lang="en">ASoT Role</skos:altLabel>
        <skos:definition xml:lang="en">A Source of Truth Role that has been assigned thru an Act of Role Assignment by a relevant Authority, and that &apos;has ASoT context&apos; of a particular Act of Digital Engineering</skos:definition>
        <skos:editorialNote xml:lang="en">An ASoT, a Digital Asset/Artifact, is such due to its being assigned the ASoT Role by an Authority</skos:editorialNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Authority -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Authority">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001017"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000187"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001787"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000133"/>
                                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001374"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00001017"/>
        <rdfs:comment xml:lang="en">An Agent such as a Person, governing body, or System that applies expert judgment and rules to proclaim a Digital Artifact is valid and originates from a sanctioned source.

Derived from source: https://www.dau.edu/glossary/asot</rdfs:comment>
        <rdfs:label xml:lang="en">Authority</rdfs:label>
        <skos:definition xml:lang="en">A Stakeholder who has the right to apply project resources, expend funds, make decisions, or give approvals</skos:definition>
        <skos:editorialNote xml:lang="en">This concept is integral to defining ASoT, which requires an Authority to assign an ASoT Role to a Digital Asset.</skos:editorialNote>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering or other domain ontology</skos:scopeNote>
        <cco:ont00001754>ISO/IEC/IEEE 24765:2017, 3.305</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Complex_Adaptive_System -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Complex_Adaptive_System">
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#System"/>
        <rdfs:comment xml:lang="en">A complex adaptive system is a system that is complex in that it is a dynamic network of interactions, but the behavior of the ensemble may not be predictable according to the behavior of the components. It is adaptive in that the individual and collective behavior mutate and self-organize corresponding to the change-initiating micro-event or collection of events.

Source: https://en.wikipedia.org/wiki/Complex_adaptive_system</rdfs:comment>
        <rdfs:label xml:lang="en">Complex Adaptive System</rdfs:label>
        <skos:scopeNote xml:lang="en">TBD: move to Systems domain ontology</skos:scopeNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Computer_Component -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Computer_Component">
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000995"/>
        <rdfs:label xml:lang="en">Computer Component</rdfs:label>
        <skos:altLabel xml:lang="en">Computer Hardware</skos:altLabel>
        <skos:definition xml:lang="en">An Artifact designed to be a component of a Computer.</skos:definition>
        <cco:ont00001760 xml:lang="en">http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology</cco:ont00001760>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Computer_Program -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Computer_Program">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000117"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000129"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000420"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000117"/>
        <rdfs:label xml:lang="en">Computer Program</rdfs:label>
        <skos:altLabel xml:lang="en">Computer Software</skos:altLabel>
        <skos:altLabel xml:lang="en">Software</skos:altLabel>
        <skos:definition xml:lang="en">An Information Processing Artifact that consists of a collection of Computer Functions that are designed to be executed by a Processing Unit to perform a specific task.</skos:definition>
        <skos:editorialNote xml:lang="en">Included in DEIX Ontology to avoid a hard requirement on Common Core Cyber Ontology, which includes many concepts unnecessary for defining DEIX concepts</skos:editorialNote>
        <cco:ont00001754>https://en.wikipedia.org/wiki/Computer_program</cco:ont00001754>
        <cco:ont00001760>http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology</cco:ont00001760>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Concern_Disposition -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Concern_Disposition">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000016"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000197"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Stakeholder"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:comment xml:lang="en">matter of interest or importance to a Stakeholder

Source: ISO/IEC/IEEE 15288:2023</rdfs:comment>
        <rdfs:label xml:lang="en">Concern Disposition</rdfs:label>
        <skos:definition xml:lang="en">A Disposition that is realized when a Stakeholder bearer identifies a matter of interest or importance</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">derived from ISO/IEC/IEEE 15288:2023</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Concern_Expression -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Concern_Expression">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000853"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001982"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Concern_Disposition"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000853"/>
        <rdfs:comment xml:lang="en">In the systems engineering domain, Concern Expressions have an associated Stakeholder that is the bearer of a particular role, e.g. Engineer Role. That is, this engineer stakeholder has expressed a concern about the system-of-interest which is then recorded in an Information Bearing Artifact and subject to change control.</rdfs:comment>
        <rdfs:label xml:lang="en">Concern Expression</rdfs:label>
        <skos:definition xml:lang="en">A Descriptive Information Content Entity that describes a Concern Disposition that a particular Stakeholder bears</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Consistency_Measurement_Information_Content_Entity -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Consistency_Measurement_Information_Content_Entity">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000731"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001808"/>
                        <owl:someValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                                <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Referent_Role"/>
                            </owl:Restriction>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001966"/>
                        <owl:someValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                                <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Subject_Role"/>
                            </owl:Restriction>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000731"/>
        <rdfs:label xml:lang="en">Consistency Measurement Information Content Entity</rdfs:label>
        <skos:definition xml:lang="en">A Deviation Measurement ICE that measures the consistency of the Subject compared to its Referent.</skos:definition>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Context_of_Use -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Context_of_Use">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000115"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#System_Environment"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000115"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#System"/>
                                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001017"/>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000183"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Activity"/>
                                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000566"/>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000027"/>
        <rdfs:label xml:lang="en">Context of Use</rdfs:label>
        <skos:definition xml:lang="en">Users, Tasks, equipment (hardware, software, and materials) (Systems), and the physical and social environments (System Environments) in which a Product is used</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754>ISO/IEC 25002:2024</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Data -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Data">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000798"/>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001816"/>
                                <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00001158"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001841"/>
                                <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00001158"/>
                            </owl:Restriction>
                        </owl:unionOf>
                    </owl:Class>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001956"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000798"/>
        <rdfs:label xml:lang="en">Data</rdfs:label>
        <skos:definition xml:lang="en">reinterpretable representation of Information Content Entit(ies) in a formalized manner suitable for Acts of Communication or Information Processing</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move to Data Management domain ontology?</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">derived from ISO/IEC 25000:2014 Systems and software engineering —Systems and software Quality Requirements and Evaluation (SQuaRE) — Guide to SQuaRE</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Data_Transfer_Function -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Data_Transfer_Function">
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000323"/>
        <rdfs:label>Data Transfer Function</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000016"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Process"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000218"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Data"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">Digital</rdfs:label>
        <skos:definition xml:lang="en">a disposition pertaining to Data that consists of digits</skos:definition>
        <skos:editorialNote xml:lang="en">part of DEIX Ontology, used to distinguish entities that are &apos;digital&apos;</skos:editorialNote>
        <cco:ont00001754 xml:lang="en">derived from ISO/IEC/IEEE 24765:2017, 3.1206</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#DigitalObject -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#DigitalObject">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000798"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000115"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Data"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001936"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Tool_Use"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000798"/>
        <rdfs:comment xml:lang="en">entity that exists in the Digital Realm

Source: ISO/IEC 20924:2024, 3.1.13</rdfs:comment>
        <rdfs:label xml:lang="en">Digital Object</rdfs:label>
        <skos:altLabel xml:lang="en">Digital Entity</skos:altLabel>
        <skos:definition xml:lang="en">An Information Bearing Artifact that is designed to bear a collection of related values.</skos:definition>
        <skos:editorialNote xml:lang="en">Copied from Common Core Cyber Ontology, since it serves as the superclass of many DEIX concepts.</skos:editorialNote>
        <cco:ont00001760>http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology</cco:ont00001760>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Artifact -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Artifact">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#DigitalObject"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000129"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Engineering_Environment"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001816"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Engineering"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#DigitalObject"/>
        <rdfs:comment xml:lang="en">Digital Artifacts provide Data for alternative Views to visualize, communicate, and deliver Data, Information, and Knowledge to Stakeholders.

Soruce: https://www.dau.edu/glossary/digital-artifact</rdfs:comment>
        <rdfs:label xml:lang="en">Digital Artifact</rdfs:label>
        <skos:definition xml:lang="en">A Product or output, in Computer (i.e., digital) format, created within or generated from the Digital Engineering Environment.</skos:definition>
        <cco:ont00001754>https://www.dau.edu/glossary/digital-artifact</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Asset -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Asset">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Asset"/>
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Artifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000101"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Traceability_Measurement_Information_Content_Entity"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000115"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Information"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Source_of_Truth_Role"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001816"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Model_Curation"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001879"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000292"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001904"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000592"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001963"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000186"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Artifact"/>
        <rdfs:label xml:lang="en">Digital Asset</rdfs:label>
        <skos:definition xml:lang="en">A curated, version-controlled Digital Artifact that carries accurate Information about an entity</skos:definition>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Authoritative_Source_of_Truth -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Authoritative_Source_of_Truth">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Asset"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000115"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Model"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Authoritative_Source_of_Truth_Role"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Asset"/>
        <rdfs:comment xml:lang="en">Potential definition: A Digital Asset that provides Traceability and Authoritative Knowledge, Information, and Data, and which bears an Authoritative Source of Truth Role assigned by an Authority

Source: adapted from discussions by INCOSE DEIX Ontology WG</rdfs:comment>
        <rdfs:comment xml:lang="en">The reference point for models and data across the system life cycle. The authoritative source of truth provides traceability as the system evolves, capturing historical knowledge and connecting configuration-controlled versions of models and data.

Source: https://www.dau.edu/glossary/authoritative-source-truth</rdfs:comment>
        <rdfs:label xml:lang="en">Digital Authoritative Source of Truth</rdfs:label>
        <skos:definition xml:lang="en">A Digital Asset that bears an ASoT Role, where that ASoT Role has a defined ASoT context of a particular Act of Digital Engineering, and which carries at least one View that addresses particular Stakeholder Concern(s)</skos:definition>
        <skos:editorialNote xml:lang="en">During Working Group discussions, we discovered that an ASoT must address a particular stakeholder concern. This is provisionally captured using &apos;is carrier of&apos; relation, but presumably a Digital Asset could contain an IBE of a Concern Expression without necessarily addressing that concern. This fault indicates we may need to define a new object property such as &apos;addresses&apos;/&apos;is addressed by&apos; with domain/range = &apos;Concern Expression&apos;/&apos;Digital Artifact&apos;, but this addition requires more discussion.</skos:editorialNote>
        <skos:editorialNote xml:lang="en">The aspect of &quot;Authoritative Knowledge, Information, and Data&quot; is currently captured by the ASoT Role that &apos;has ASoT Context&apos;, which makes those authoritative, and by ASoT being a subclass of Digital Asset which is the carrier of particular ICEs that increase its authoritativeness. (Comments welcome.)</skos:editorialNote>
        <cco:ont00001753 xml:lang="en">Digital ASoT</cco:ont00001753>
        <cco:ont00001754 xml:lang="en">INCOSE DEIX WG</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Ecosystem -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Ecosystem">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Ecosystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000178"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Computer_Program"/>
                                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Environment"/>
                                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000509"/>
                                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001180"/>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000183"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000836"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Ecosystem"/>
        <rdfs:comment xml:lang="en">Defined as a set of businesses functioning as a unit and interacting with a shared market for software and services, together with relationships among them. These relationships are frequently underpinned by a common technological platform and operate through the exchange of information, resources, and artifacts.

Source: https://en.wikipedia.org/wiki/Digital_ecosystem</rdfs:comment>
        <rdfs:label xml:lang="en">Digital Ecosystem</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Digital_ecosystem</rdfs:seeAlso>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Software_ecosystem</rdfs:seeAlso>
        <skos:definition xml:lang="en">distributed, adaptive, open Socio-Technical System with properties of self-organization, scalability and sustainability inspired from natural ecosystems</skos:definition>
        <cco:ont00001754 xml:lang="en">ISO/IEC TS 30105-9:2023, 3.3</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Engineering_Approach -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Engineering_Approach">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Engineering_Approach"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001942"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Engineering"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Engineering_Approach"/>
        <rdfs:label xml:lang="en">Digital Engineering Approach</rdfs:label>
        <skos:definition xml:lang="en">An integrated Digital Approach that uses Authoritative Sources of systems’ Data and Models as a continuum across Disciplines to support Lifecycle Activities from Concept Stage through Retirement Stage.</skos:definition>
        <skos:editorialNote xml:lang="en">Used to disambiguate &quot;Digital Engineering&quot;</skos:editorialNote>
        <cco:ont00001754>https://www.dau.edu/glossary/digital-engineering</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Engineering_Ecosystem -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Engineering_Ecosystem">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Ecosystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000178"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Engineering_Environment"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000183"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Engineering"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Ecosystem"/>
        <rdfs:comment xml:lang="en">The Digital Engineering ecosystem can be vast, crossing engineering domain and organizational boundaries. The Digital Engineering ecosystem should be treated as an SoS and must be developed using SE good practices. The Digital Engineering ecosystem consists of the models, tools, processes, and people/roles that come together to develop the systems the organization cares about. The ecosystem can be broader than this, depending on the scope. For example, some organizations utilize their Digital Engineering ecosystems to support the operation of their systems. Others include cross-project libraries and methods in their Digital Engineering ecosystems, as well as interconnections with external Digital Engineering ecosystems across their supply chain.

Source: INCOSE Systems Engineering Handbook, Fifth Edition (2023)</rdfs:comment>
        <rdfs:label xml:lang="en">Digital Engineering Ecosystem</rdfs:label>
        <skos:definition xml:lang="en">A Digital Ecosystem encompassing some shared market(s) of Organizations and their Products and Services, whose Digital Environments, including Digital Engineering Environments, are networked to share Resources, Artifacts, and Information.</skos:definition>
        <cco:ont00001754 xml:lang="en">derived from https://en.wikipedia.org/wiki/Digital_ecosystem</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Engineering_Environment -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Engineering_Environment">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Environment"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000183"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Engineering"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Environment"/>
        <rdfs:label xml:lang="en">Digital Engineering Environment</rdfs:label>
        <skos:definition xml:lang="en">A Digital Environment used to store, access, analyze, and visualize evolving Systems&apos; Data and Models to address the Needs of the Stakeholders.</skos:definition>
        <skos:editorialNote xml:lang="en">Essential concept in Digital Engineering; distinguished from Digital Engineering Ecosystem; is a subclass of digital (IT) environment</skos:editorialNote>
        <cco:ont00001754>derived from https://www.dau.edu/glossary/digital-engineering-ecosystem</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Environment -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Environment">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000700"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000115"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Tool"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000183"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Data_Transfer"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000700"/>
        <rdfs:comment xml:lang="en">Major components of a digital environment generally include websites, cloud servers, search engines, social media outlets, mobile apps, audio and video, and other web-based resources.</rdfs:comment>
        <rdfs:comment xml:lang="en">May be a System Environment if a Software System is deployed to the Digital Environment. Otherwise, it may be the SoI itself.</rdfs:comment>
        <rdfs:comment xml:lang="en">The concept is based on digital electronics systems which are integrated and implemented for a global community.</rdfs:comment>
        <rdfs:label xml:lang="en">Digital Environment</rdfs:label>
        <skos:definition xml:lang="en">an integrated Computer Network where Computers communicate and manage the Information Bearing Artifacts and Activities within it.</skos:definition>
        <skos:scopeNote xml:lang="en">Serves as superclass of Digital Engineering Environment; possibly can be refactored to a digital enterprise domain ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">https://en.wikipedia.org/wiki/Digital_environments</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Information -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Information">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Data"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000115"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000253"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001936"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000366"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Data"/>
        <rdfs:label xml:lang="en">Digital Information</rdfs:label>
        <skos:definition xml:lang="en">Data that are processed, organized and correlated to produce meaning</skos:definition>
        <skos:editorialNote xml:lang="en">Digital Information is curated Data, and is Information given concrete form</skos:editorialNote>
        <skos:scopeNote xml:lang="en">TBR: move to Data Management domain ontology?</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">ISO 5127:2017 — Information and documentation — Foundation and vocabulary, 3.1.1.16</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Instance -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Instance">
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Twin"/>
        <rdfs:comment xml:lang="en">A virtual replica of the physical configuration of an existing entity. The digital instance typically exists to replicate each individual configuration of a product as-built or as-maintained.

Source: https://www.dau.edu/glossary/digital-instance</rdfs:comment>
        <rdfs:label xml:lang="en">Digital Instance</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Model -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Model">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Artifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000101"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00001069"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Artifact"/>
        <rdfs:comment xml:lang="en">Digital Models may also carry Descriptive ICEs, Directive ICEs, and Designative ICEs</rdfs:comment>
        <rdfs:label xml:lang="en">Digital Model</rdfs:label>
        <skos:definition xml:lang="en">A Digital Artifact that carries a Representational ICE of an object, phenomenon, process, or System.</skos:definition>
        <cco:ont00001754 xml:lang="en">derived from https://www.dau.edu/glossary/digital-model</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Model_Lifecycle -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Model_Lifecycle">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Information_Artifact_Lifecycle"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000184"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Model"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Information_Artifact_Lifecycle"/>
        <rdfs:label xml:lang="en">Digital Model Lifecycle</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Process -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Process">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000110"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001949"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Data"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000110"/>
        <rdfs:label xml:lang="en">Digital Process</rdfs:label>
        <skos:definition xml:lang="en">a Mechanical Process that uses Data</skos:definition>
        <skos:editorialNote xml:lang="en">part of DEIX Ontology</skos:editorialNote>
        <cco:ont00001754 xml:lang="en">derived from ISO/IEC/IEEE 24765:2017, 3.1206</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Prototype -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Prototype">
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Twin"/>
        <rdfs:comment xml:lang="en">An integrated multi-physics, multiscale, probabilistic model of a system design. The digital prototype may use sensor information and input data to simulate the performance of its corresponding physical twin. The digital prototype may exist prior to realization of its physical counterpart.

Source: https://www.dau.edu/glossary/digital-prototype</rdfs:comment>
        <rdfs:label xml:lang="en">Digital Prototype</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Realm -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Realm">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000591"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000124"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#DigitalObject"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000591"/>
        <rdfs:comment xml:lang="en">derived from Digital Realm mentioned, but not defined in, Source: ISO/IEC 20924:2024</rdfs:comment>
        <rdfs:label xml:lang="en">Digital Realm</rdfs:label>
        <skos:definition xml:lang="en">An Artifact Location of a Digital Object(s).</skos:definition>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Repository -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Repository">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000756"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000101"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000186"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000115"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Artifact"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000756"/>
        <rdfs:label xml:lang="en">Digital Repository</rdfs:label>
        <skos:definition xml:lang="en">a change-controlled Database that contains Digital Artifacts</skos:definition>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Representation -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Representation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Model"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000101"/>
                        <owl:someValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001938"/>
                                <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Observable_Element"/>
                            </owl:Restriction>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Model"/>
        <rdfs:label xml:lang="en">Digital Representation</rdfs:label>
        <skos:altLabel xml:lang="en">Virtual Representation</skos:altLabel>
        <skos:definition xml:lang="en">A Digital Model representing either a set of properties or Behaviours or both of one or more Observable Elements</skos:definition>
        <skos:editorialNote xml:lang="en">The more general definition from ISO/IEC 30173:2023 is used here, instead of the one focused on Observable Manufacturing Element from ISO 23247-1:2021.</skos:editorialNote>
        <cco:ont00001754 xml:lang="en">ISO/IEC 30173:2023 - Digital twin — Concepts and terminology</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_System_Model -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_System_Model">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Representation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000101"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#System_Model"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000101"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000686"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000101"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000853"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000115"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_View"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Representation"/>
        <rdfs:comment xml:lang="en">In MBSE and Digital Engineering, a Digital System Model is a digital representation of a system. It integrates the authoritative MBSE and other Digital Engineering technical data and associated artifacts, defining all aspects of the system throughout the system life cycle. The Digital System Model is composed of a federated set of models that serve as an authoritative source of truth (ASOT) for the system’s design. Digital Engineering leverages MBSE and the Digital System Model to enable digital threads and digital twins.

Source: INCOSE Systems Engineering Handbook, Fifth Edition</rdfs:comment>
        <rdfs:label xml:lang="en">Digital System Model</rdfs:label>
        <skos:definition xml:lang="en">A Digital Model of a System, generated by all Stakeholders that integrates the Authoritative Source(s) of Truth and associated Digital Artifacts which define all aspects of the System for the specific Activities throughout the System Lifecycle.</skos:definition>
        <skos:editorialNote xml:lang="en">TBR: Should &apos;Digital System Model&apos; more closely follow the DAU definition, which narrows its meaning, or should it follow the simpler ontological convention?</skos:editorialNote>
        <cco:ont00001754 rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.dau.edu/glossary/digital-system-model</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_System_View -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_System_View">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_View"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000101"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#System_View"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_View"/>
        <rdfs:label xml:lang="en">Digital System View</rdfs:label>
        <skos:definition xml:lang="en">A Digital View of a System</skos:definition>
        <skos:editorialNote xml:lang="en">present in the literature but may not be needed in the ontology</skos:editorialNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Thread_Consistency -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Thread_Consistency">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000314"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000059"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Consistency_Measurement_Information_Content_Entity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000314"/>
        <rdfs:label xml:lang="en">Digital Thread Consistency</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Thread_Role -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Thread_Role">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000023"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Measuring_Consistency"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">Digital Thread Role</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Tool -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Tool">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Computer_Program"/>
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000581"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000178"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Artifact"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000932"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000581"/>
        <rdfs:comment xml:lang="en">a Computer Program designed to be used as a Tool by an Operator</rdfs:comment>
        <rdfs:label xml:lang="en">Digital Tool</rdfs:label>
        <skos:editorialNote xml:lang="en">An essential distinction we use in Digital Engineering is about Tools which produce Digital Artifacts</skos:editorialNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Twin -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Twin">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_System_Model"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000056"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Synchronization_Process"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000101"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Lifeycle_View"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000101"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#System_View"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_System_Model"/>
        <rdfs:comment xml:lang="en">A Digital Twin is a Virtual Representation of a connected physical Asset.

Source: Digital Twin: Definition &amp; Value - AIAA Position Paper (December 2020)</rdfs:comment>
        <rdfs:comment xml:lang="en">A digital twin is a digital surrogate of the system, incorporating models to emulate the actual system or some of its elements. The digital twin evolves through the life cycle with the mission and definition of the system.

Source: INCOSE Systems Engineering Handbook, Fifth Edition (2023)</rdfs:comment>
        <rdfs:comment xml:lang="en">A virtual replica of a physical entity that is synchronized across time.

Source: https://www.dau.edu/glossary/digital-twin</rdfs:comment>
        <rdfs:comment xml:lang="en">Digital Twins exist to replicate configuration, performance, or history of a System.</rdfs:comment>
        <rdfs:comment xml:lang="en">Two primary sub-categories of Digital Twin are Digital Instance and Digital Prototype.</rdfs:comment>
        <rdfs:label xml:lang="en">Digital Twin</rdfs:label>
        <skos:altLabel xml:lang="en">Virtual Twin</skos:altLabel>
        <skos:definition xml:lang="en">A fit-for-purpose Digital Representation of an Observable Manufacturing Element with syncronization between the element and its Digital Representation</skos:definition>
        <cco:ont00001754 xml:lang="en">ISO 23247-1:2021 Automation systems and integration - Digital twin framework for manufacturing - Part 1: Overview and general principles</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Twin_Role -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Twin_Role">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000023"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Synchronization_Process"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">Digital Twin Role</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Twin_System -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Twin_System">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Engineered_System"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000115"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Twin"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000115"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#System"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000183"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Simulation"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000183"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000345"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Engineered_System"/>
        <rdfs:label xml:lang="en">Digital Twin System</rdfs:label>
        <skos:definition xml:lang="en">A System providing functionalities for the Digital Twin composed of inter-operating Target Entities, Digital Entities, data connections, and Digital Models, Data and Interfaces involved in the data connection process.</skos:definition>
        <cco:ont00001754>ISO/IEC 30173:2023, 3.1.21</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_View -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_View">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Model"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000101"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#View"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Model"/>
        <rdfs:label xml:lang="en">Digital View</rdfs:label>
        <skos:definition xml:lang="en">A Digital Model of an entity from the perspective of a related set of Concerns</skos:definition>
        <skos:editorialNote xml:lang="en">not in the DAU glossary; counterpart to View, identified by the WG but may not be necessary for the ontology.</skos:editorialNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Digital_Viewpoint -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Viewpoint">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Digital_Artifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000101"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Viewpoint"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Artifact"/>
        <rdfs:label xml:lang="en">Digital Viewpoint</rdfs:label>
        <skos:definition xml:lang="en">A Digital Artifact that carries a Viewpoint specification</skos:definition>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Ecosystem -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Ecosystem">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000115"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Stakeholder"/>
                            <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000509"/>
                            <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000870"/>
                            <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001180"/>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Complex_Adaptive_System"/>
        <rdfs:label xml:lang="en">Ecosystem</rdfs:label>
        <skos:definition xml:lang="en">Infrastructure and Services based on a network of Organizations and Stakeholders</skos:definition>
        <cco:ont00001754>ISO/IEC TS 27400:2022, 3.8</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Engineered_System -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Engineered_System">
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#System"/>
        <rdfs:comment xml:lang="en">A System designed or adapted to interact with an anticipated Operational Environment to achieve one or more intended Purposes while complying with applicable Constraints.</rdfs:comment>
        <rdfs:label xml:lang="en">Engineered System</rdfs:label>
        <skos:scopeNote xml:lang="en">TBD: move to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">https://sebokwiki.org/wiki/Engineered_System_(glossary)</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Engineering_Approach -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Engineering_Approach">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Approach"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001942"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Engineering"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Approach"/>
        <rdfs:label xml:lang="en">Engineering Approach</rdfs:label>
        <skos:scopeNote xml:lang="en">TBR: move concept to Engineering domain ontology</skos:scopeNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Functional_Unit -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Functional_Unit">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000740"/>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Computer_Component"/>
                            <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Computer_Program"/>
                            <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000420"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000740"/>
        <rdfs:label xml:lang="en">Functional Unit</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital"/>
        <skos:definition xml:lang="en">An entity of Computer Hardware or Software, or both (Computer), capable of accomplishing a specified Purpose</skos:definition>
        <skos:editorialNote xml:lang="en">included due to its reference in definition of Digital from ISO 24765</skos:editorialNote>
        <skos:scopeNote xml:lang="en">TBR: move to Systems Engineering ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">ISO/IEC/IEEE 24765:2017, 3.1713</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Information_Artifact_Lifecycle -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Information_Artifact_Lifecycle">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Lifecycle"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000184"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000798"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Lifecycle"/>
        <rdfs:label xml:lang="en">Information Artifact Lifecycle</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Knowledge -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Knowledge">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000958"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001816"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000366"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000958"/>
        <rdfs:label xml:lang="en">Knowledge</rdfs:label>
        <skos:definition xml:lang="en">maintained, processed, and interpreted Information Content Entit(ies)</skos:definition>
        <skos:editorialNote xml:lang="en">Serves as the superclass of Authoritative Knowledge, which is part of the DEIX Ontology</skos:editorialNote>
        <cco:ont00001754 xml:lang="en">ISO 5127:2017 — Information and documentation — Foundation and vocabulary</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Lifecycle -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Lifecycle">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000184"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000182"/>
        <rdfs:label xml:lang="en">Lifecycle</rdfs:label>
        <skos:altLabel xml:lang="en">Life cycle</skos:altLabel>
        <skos:definition xml:lang="en">An Artifact History of a System, Product, Service, Project or other human-made entity from Conception Phase through Retirement Phase</skos:definition>
        <skos:editorialNote xml:lang="en">TBR: Consider revising to not limit to system - could be &apos;history of&apos; entity, which is missing from the CCO &apos;Artifact History&apos; axioms. &apos;System Lifecycle&apos; can be a simple subclass.</skos:editorialNote>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">derived from ISO/IEC/IEEE 15288:2023</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Lifeycle_View -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Lifeycle_View">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#View"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001938"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Lifecycle"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#View"/>
        <rdfs:label>Lifecycle View</rdfs:label>
        <skos:definition xml:lang="en">A View that represents some Lifecycle</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move to Systems Engineering domain ontology</skos:scopeNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Model-Based_Engineering_Approach -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Model-Based_Engineering_Approach">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Engineering_Approach"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001808"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#System_Model"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Engineering_Approach"/>
        <rdfs:label xml:lang="en">Model-Based Engineering Approach</rdfs:label>
        <skos:definition xml:lang="en">An Engineering Approach that is focused on the use of System Model(s)</skos:definition>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Observable_Element -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Observable_Element">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000740"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001936"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000037"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000740"/>
        <rdfs:label xml:lang="en">Observable Element</rdfs:label>
        <skos:definition xml:lang="en">A Resource that is the object of an Act of Observation.</skos:definition>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Observable_Manufacturing_Element -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Observable_Manufacturing_Element">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Observable_Element"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000056"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00001359"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Observable_Element"/>
        <rdfs:label xml:lang="en">Observable Manufacturing Element</rdfs:label>
        <skos:definition xml:lang="en">A Resource that has an observable physical presence or operation in an Act of Manufacturing</skos:definition>
        <skos:editorialNote xml:lang="en">Included in DEIX Ontology because it is directly related to the definition of Digital Twin</skos:editorialNote>
        <skos:example xml:lang="en">OMEs include personnel, equipment, material, process, facility, environment, product, and supporting document.</skos:example>
        <skos:scopeNote xml:lang="en">TBD: May be more appropriate in an Industry 4.0 ontology.</skos:scopeNote>
        <cco:ont00001753 xml:lang="en">OME</cco:ont00001753>
        <cco:ont00001754 xml:lang="en">ISO 23247-1:2021 Automation systems and integration - Digital twin framework for manufacturing - Part 1: Overview and general principles</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Operational_Environment -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Operational_Environment">
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#System_Environment"/>
        <rdfs:label xml:lang="en">Operational Environment</rdfs:label>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Process_Outcome -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Process_Outcome">
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000660"/>
        <rdfs:label xml:lang="en">Process Outcome</rdfs:label>
        <skos:altLabel xml:lang="en">Outcome</skos:altLabel>
        <skos:definition xml:lang="en">observable result of the successful achievement of the Process Purpose</skos:definition>
        <skos:scopeNote xml:lang="en">Omitting the definition of Process Purpose for now, as it is a subclass of Need and Purpose

Process Outcome =Def Effect and (&apos;prescribed by&apos; some &apos;Process Purpose&apos;)</skos:scopeNote>
        <skos:scopeNote xml:lang="en">TBR: move concept to Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754>ISO/IEC/IEEE 15288:2023</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Referent_Role -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Referent_Role">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">Referent Role</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Source_of_Truth_Role -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Source_of_Truth_Role">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000023"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000197"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000798"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">Source of Truth Role</rdfs:label>
        <skos:altLabel xml:lang="en">SoT Role</skos:altLabel>
        <skos:definition xml:lang="en">A role that inheres in an Information Bearing Artifact that establishes it as a source of truth for the Information Content Entit(ies) it carries in a particular Context of Use</skos:definition>
        <skos:editorialNote xml:lang="en">Originally &quot;Digital Source of Truth Role&quot; - simplified to &quot;Source of Truth Role&quot; since it need not relate to a Digital Artifact. (2025-04-08)</skos:editorialNote>
        <skos:scopeNote xml:lang="en">TBC: part of DEIX Ontology</skos:scopeNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Stakeholder -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Stakeholder">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001017"/>
                            <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001180"/>
                        </owl:unionOf>
                    </owl:Class>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001787"/>
                                <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Lifecycle"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001984"/>
                                <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Lifecycle"/>
                            </owl:Restriction>
                        </owl:unionOf>
                    </owl:Class>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Concern_Disposition"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Stakeholder_Role"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00001017"/>
        <rdfs:label xml:lang="en">Stakeholder</rdfs:label>
        <skos:definition xml:lang="en">individual or Organization having a right, share, claim, or interest in a System or in its possession of characteristics that meet their Needs and expectations</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754>ISO/IEC/IEEE 15288:2023</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Stakeholder_Role -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Stakeholder_Role">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">Stakeholder Role</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://semantic.incose.org/DEIX_Ontology#Stakeholder"/>
        <skos:definition xml:lang="en">A Role that inheres in some Agent who has some stake in an entity of interest</skos:definition>
        <skos:editorialNote xml:lang="en">counterpart of Stakeholder (subclass of Agent)</skos:editorialNote>
        <skos:scopeNote xml:lang="en">TBD: move to Systems Engineering ontology</skos:scopeNote>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Subject_Role -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Subject_Role">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">Subject Role</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Synchronization_Process -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Synchronization_Process">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000110"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001777"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00001158"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001777"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00001330"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000110"/>
        <rdfs:label xml:lang="en">Synchronization Process</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#System -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#System">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000115"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#System_Element"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001787"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00001347"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001901"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000038"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000027"/>
        <rdfs:label xml:lang="en">System</rdfs:label>
        <skos:definition xml:lang="en">arrangement of Parts or elements that together exhibit a stated Behavior or meaning that the individual constituents do not.</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">ISO/IEC/IEEE 15288:2023</cco:ont00001754>
        <cco:ont00001754 xml:lang="en">https://en.wikipedia.org/wiki/System</cco:ont00001754>
        <cco:ont00001754 xml:lang="en">https://sebokwiki.org/wiki/System_(glossary)</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#System_Element -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#System_Element">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001901"/>
                <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000929"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000027"/>
        <rdfs:label xml:lang="en">System Element</rdfs:label>
        <skos:altLabel xml:lang="en">Component</skos:altLabel>
        <skos:altLabel xml:lang="en">System Part</skos:altLabel>
        <skos:definition xml:lang="en">discrete part of a System that can be implemented to fulfil specified Requirements.</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754>ISO/IEC/IEEE 15288:2023</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#System_Environment -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#System_Environment">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000178"/>
                        <owl:someValuesFrom rdf:resource="https://www.commoncoreontologies.org/ont00000574"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000178"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Operational_Environment"/>
                                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#V&amp;V_Environment"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000183"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Lifecycle"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000027"/>
        <rdfs:comment xml:lang="en">context determining the setting and circumstances of all influences upon System</rdfs:comment>
        <rdfs:label xml:lang="en">System Environment</rdfs:label>
        <skos:definition xml:lang="en">The surroundings (natural or man‐made) in which the SoI is utilized and supported or in which the System is being developed, produced, and retired.</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">INCOSE (2023). Systems Engineering Handbook, Fifth Edition. No. INCOSE-TP-2003-002-05. ISBN: 9781119814306</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#System_Lifecycle -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#System_Lifecycle">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Lifecycle"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000184"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#System"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Lifecycle"/>
        <rdfs:label xml:lang="en">System Lifecycle</rdfs:label>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#System_Model -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#System_Model">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001045"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001942"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#System"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00001045"/>
        <rdfs:comment xml:lang="en">The provided definition is derived from the INCOSE Systems Engineering Handbook section of prose, 2.3.5.6 System Analysis Process, in lieu of a glossary term. The term is not mentioned in ISO/IEC/IEEE 15288:2023, and not defined in the SEBoK. ISO/IEC/IEEE 24765:2017 has a definition of &apos;system model&apos; that is only applicable to the computer performance evaluation domain.</rdfs:comment>
        <rdfs:label xml:lang="en">System Model</rdfs:label>
        <skos:definition xml:lang="en">An Artifact Model that prescribes a System and uses &quot;quantitative (numerical) and qualitative (categorical) variables to represent system attributes along multiple dimensions&quot;</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">INCOSE Systems Engineering Handbook, Fifth Edition</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#System_View -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#System_View">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#View"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001938"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#System"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#View"/>
        <rdfs:label xml:lang="en">System View</rdfs:label>
        <skos:definition xml:lang="en">A representation of a System from the perspective of a related set of Concerns</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">adapted from ISO/IEC/IEEE 15288:2023</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#System_Viewpoint -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#System_Viewpoint">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://semantic.incose.org/DEIX_Ontology#Viewpoint"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001942"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#System_View"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#Viewpoint"/>
        <rdfs:label xml:lang="en">System Viewpoint</rdfs:label>
        <skos:definition xml:lang="en">A specification of the conventions for constructing and using a System View</skos:definition>
        <cco:ont00001754 xml:lang="en">adapted from ISO/IEC/IEEE 15288:2023</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Target_Entity -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Target_Entity">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000544"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001801"/>
                        <owl:someValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000084"/>
                                <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Digital_Representation"/>
                            </owl:Restriction>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000544"/>
        <rdfs:comment xml:lang="en">The target entity, which provides some functional purpose in reality, can be either physical or digital under consideration.

Source: ISO/IEC 20924:2024</rdfs:comment>
        <rdfs:label xml:lang="en">Target Entity</rdfs:label>
        <skos:definition xml:lang="en">A Target providing a functional purpose in reality which is the subject of Digital Representation</skos:definition>
        <skos:editorialNote xml:lang="en">Arguably, Target is acceptable, but we include Target Entity because it is specifically defined in ISO/IEC 30173, creating the opportunity for a more specific equivalence axiom.</skos:editorialNote>
        <cco:ont00001754 xml:lang="en">derived from ISO/IEC 30173:2023, 3.1.3</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Task -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Task">
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000228"/>
        <rdfs:label xml:lang="en">Task</rdfs:label>
        <skos:definition xml:lang="en">required, recommended, or permissible action, intended to contribute to the achievement of one or more outcomes of a process</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754>ISO/IEC/IEEE 15288:2023</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Thread_Description_Information_Content_Entity -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Thread_Description_Information_Content_Entity">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000853"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000056"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Lifecycle"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000178"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Traceability_Measurement_Information_Content_Entity"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001936"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Measuring_Consistency"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000853"/>
        <rdfs:comment xml:lang="en">An extensible and configurable analytical framework that seamlessly expedites the controlled interplay of technical Data, Software, Information, and Knowledge in the Digital Engineering Ecosystem, based on the established Requirements, Architectures, formats, and rules for building Digital Artifact Models.

Source: https://www.dau.edu/glossary/digital-thread</rdfs:comment>
        <rdfs:comment xml:lang="en">Digital Threads can be used to produce Digital Artifacts that are a combination of Authoritative Data, Information, Knowledge, and wisdom addressing Stakeholders’ unique perspective.

Source: INCOSE Systems Engineering Handbook, Fifth Edition (2023)</rdfs:comment>
        <rdfs:comment xml:lang="en">It is used to inform decision makers throughout a System&apos;s Lifecycle by providing the Capability to access, integrate, and transform Data into actionable Information.

Source: https://www.dau.edu/glossary/digital-thread</rdfs:comment>
        <rdfs:label xml:lang="en">Thread Description Information Content Entity</rdfs:label>
        <skos:definition xml:lang="en">A Descriptive Information Content Entity composed of Traceability Measurement Information Content Entities whose consistency is actively managed over the Lifecycle of a Product, process, or System.</skos:definition>
        <skos:editorialNote xml:lang="en">Since a Digital Thread is not limited to Systems, the more generic &apos;Digital Artifact&apos; is used here.</skos:editorialNote>
        <cco:ont00001754 xml:lang="en">derived from &quot;Digital Thread: Definition, Value, and Reference Model&quot; (AIAA Position Paper, published June 2023)</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Traceability_Measurement_Information_Content_Entity -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Traceability_Measurement_Information_Content_Entity">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001163"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001966"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Traceability_Relationship"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00001163"/>
        <rdfs:label xml:lang="en">Traceability Measurement Information Content Entity</rdfs:label>
        <skos:editorialNote xml:lang="en">TBR: Is Traceability a Deviation or Veracity Measurement ICE, or something else?</skos:editorialNote>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001753 xml:lang="en">A Measurement Information Content Entity that describes the Traceability Relationship among two or more logical entities</cco:ont00001753>
        <cco:ont00001754>ISO/IEC/IEEE 15288:2023</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Traceability_Observation_Artifact_Function -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Traceability_Observation_Artifact_Function">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001306"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000059"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Traceability_Measurement_Information_Content_Entity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00001306"/>
        <rdfs:label xml:lang="en">Traceability Observation Artifact Function</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://semantic.incose.org/DEIX_Ontology#Traceability_Measurement_Information_Content_Entity"/>
        <skos:definition xml:lang="en">An Observation Artifact Function that is realized during events in which an Artifact is used to discern an association among two or more logical entities.</skos:definition>
        <skos:scopeNote xml:lang="en">TBR: move to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">derived from ISO/IEC/IEEE 15288:2023, 3.52</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Traceability_Relationship -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Traceability_Relationship">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000145"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000059"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Traceability_Measurement_Information_Content_Entity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
        <rdfs:label xml:lang="en">Traceability Relationship</rdfs:label>
        <skos:definition xml:lang="en">A relational quality which is a discernible association among two or more logical entities</skos:definition>
        <skos:example xml:lang="en">Logical entities may include Requirements, System Element, Verifications, or Tasks</skos:example>
        <skos:scopeNote xml:lang="en">TBR: move to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754>ISO/IEC/IEEE 15288:2023, 3.52</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#View -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#View">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00001069"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001920"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Viewpoint"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00001069"/>
        <rdfs:label xml:lang="en">View</rdfs:label>
        <skos:definition xml:lang="en">A representation of an entity from the perspective of a related set of Concerns</skos:definition>
        <skos:editorialNote xml:lang="en">View may represent a process, so it is not restricted to representing a System</skos:editorialNote>
        <skos:scopeNote xml:lang="en">TBR: move concept to Systems Engineering domain ontology</skos:scopeNote>
        <cco:ont00001754 xml:lang="en">adapted from ISO/IEC/IEEE 15288:2023</cco:ont00001754>
    </owl:Class>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#Viewpoint -->

    <owl:Class rdf:about="https://semantic.incose.org/DEIX_Ontology#Viewpoint">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.commoncoreontologies.org/ont00000965"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.commoncoreontologies.org/ont00001808"/>
                        <owl:someValuesFrom rdf:resource="https://semantic.incose.org/DEIX_Ontology#Concern_Expression"/>
