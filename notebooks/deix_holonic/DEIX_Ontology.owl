<?xml version="1.0"?>
<rdf:RDF xmlns="https://semantic.incose.org/DEIX_Ontology#"
     xml:base="https://semantic.incose.org/DEIX_Ontology"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:cco="https://www.commoncoreontologies.org/"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://semantic.incose.org/DEIX_Ontology">
        <owl:versionIRI rdf:resource="https://semantic.incose.org/DEIX_Ontology/v0.1"/>
        <owl:imports rdf:resource="https://www.commoncoreontologies.org/2024-11-06/AllCoreOntology"/>
        <dc:contributor>Allen Chow</dc:contributor>
        <dc:contributor>Bill Hubbard</dc:contributor>
        <dc:contributor>Celia Tseng</dc:contributor>
        <dc:contributor>Clarence Moreland</dc:contributor>
        <dc:contributor>Frank Salvatore</dc:contributor>
        <dc:contributor>James S. Wheaton</dc:contributor>
        <dc:contributor>Joe Gregory</dc:contributor>
        <dc:contributor>Joe Marvin</dc:contributor>
        <dc:contributor>Ryan Noguchi</dc:contributor>
        <dc:contributor>Terri Chan</dc:contributor>
        <dc:contributor>Zachary Welz</dc:contributor>
        <dc:creator xml:lang="en">INCOSE DEIX Taxonomy WG</dc:creator>
        <dc:description xml:lang="en">Ontology for Digital Engineering Information Exchange</dc:description>
        <dc:license>Apache-2.0</dc:license>
        <terms:title xml:lang="en">INCOSE DEIX Ontology based on Common Core Ontologies (CCO)</terms:title>
        <owl:versionInfo rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-04-08</owl:versionInfo>
    </owl:Ontology>
    


