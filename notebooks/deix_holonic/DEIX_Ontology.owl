    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://semantic.incose.org/DEIX_Ontology#assigns -->

    <owl:ObjectProperty rdf:about="https://semantic.incose.org/DEIX_Ontology#assigns">
        <owl:inverseOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#is_assigned_by"/>
        <rdfs:domain rdf:resource="https://www.commoncoreontologies.org/ont00001017"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">assigns</rdfs:label>
        <skos:definition xml:lang="en">A relation between an Agent and a role where that Agent performs an Act of Role Assignment with that role as its object.</skos:definition>
        <skos:editorialNote xml:lang="en">Provisional. Feedback welcome.</skos:editorialNote>
    </owl:ObjectProperty>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#has_ASOT_Context -->

    <owl:ObjectProperty rdf:about="https://semantic.incose.org/DEIX_Ontology#has_ASOT_Context">
        <owl:inverseOf rdf:resource="https://semantic.incose.org/DEIX_Ontology#sets_ASoT_context"/>
        <rdfs:domain rdf:resource="https://semantic.incose.org/DEIX_Ontology#Authoritative_Source_of_Truth_Role"/>
        <rdfs:range rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Engineering"/>
        <rdfs:label xml:lang="en">has ASoT context</rdfs:label>
        <skos:definition xml:lang="en">A relation between an ASoT Role and an Act of Digital Engineering that sets the context when and where that ASoT Role is true.</skos:definition>
        <skos:editorialNote xml:lang="en">Essential to the meaning of Authoritative Source of Truth</skos:editorialNote>
    </owl:ObjectProperty>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#is_assigned_by -->

    <owl:ObjectProperty rdf:about="https://semantic.incose.org/DEIX_Ontology#is_assigned_by">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:range rdf:resource="https://www.commoncoreontologies.org/ont00001017"/>
        <rdfs:label xml:lang="en">is assigned by</rdfs:label>
        <skos:definition xml:lang="en">Inverse of assigns.</skos:definition>
        <skos:editorialNote xml:lang="en">Provisional. Feedback welcome.</skos:editorialNote>
    </owl:ObjectProperty>
    


    <!-- https://semantic.incose.org/DEIX_Ontology#sets_ASoT_context -->

    <owl:ObjectProperty rdf:about="https://semantic.incose.org/DEIX_Ontology#sets_ASoT_context">
        <rdfs:domain rdf:resource="https://semantic.incose.org/DEIX_Ontology#Act_of_Digital_Engineering"/>
        <rdfs:range rdf:resource="https://semantic.incose.org/DEIX_Ontology#Authoritative_Source_of_Truth_Role"/>
        <rdfs:label xml:lang="en">sets ASoT context</rdfs:label>
        <skos:definition xml:lang="en">A relation between an Act of Digital Engineering and ASoT Role that sets the ASoT context of the Digital Asset</skos:definition>
    </owl:ObjectProperty>
    


